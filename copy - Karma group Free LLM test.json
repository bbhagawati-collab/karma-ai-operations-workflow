    {
      "parameters": {
        "jsCode": "// Read the JSON string from Ollama\nlet jsonString = $input.first().json.content;\n\n// Remove markdown if Ollama ever returns it\njsonString = jsonString.replace(/```json/g, \"\");\njsonString = jsonString.replace(/```/g, \"\");\n\n// Remove escaped newlines and tabs\njsonString = jsonString.replace(/\\\\n/g, \"\");\njsonString = jsonString.replace(/\\\\t/g, \"\");\n\n// Remove escaped quotes\njsonString = jsonString.replace(/\\\\\"/g, '\"');\n\n// Trim whitespace\njsonString = jsonString.trim();\n\n// Parse JSON\nconst parsed = JSON.parse(jsonString);\n\n// Return parsed object\nreturn [\n  {\n    json: parsed\n  }\n];"
      },
